# Force LF for all text so deploy scripts work on Linux regardless of author OS.
* text=auto eol=lf

*.sh   text eol=lf
*.py   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.toml text eol=lf

# Binary artifacts — never touch line endings.
*.png binary
*.gz  binary
*.zip binary
*.whl binary
